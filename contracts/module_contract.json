{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Camazotz Module Contract",
  "type": "object",
  "required": ["module_name", "version", "tools"],
  "properties": {
    "module_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
