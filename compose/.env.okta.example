# Okta identity provider configuration for camazotz.
#
# 1. Create a free Okta Developer account at https://developer.okta.com
# 2. Create an API Services (M2M) application:
#      Applications > Create App Integration > API Services
# 3. Copy the Client ID and Client Secret below.
# 4. Use the "default" authorization server, or create a custom one
#    under Security > API > Authorization Servers.
#
# Okta authorization server URL patterns:
#   Default:  https://{your-org}.okta.com/oauth2/default
#   Custom:   https://{your-org}.okta.com/oauth2/{server-id}
#   Org:      https://{your-org}.okta.com  (limited — no custom scopes)
#
# See docs/guides/okta-setup.md for the full walkthrough.

OKTA_ISSUER_URL=https://your-org.okta.com/oauth2/default
OKTA_TOKEN_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/token
OKTA_INTROSPECTION_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/introspect
OKTA_REVOCATION_ENDPOINT=https://your-org.okta.com/oauth2/default/v1/revoke
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
