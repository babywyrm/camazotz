# Okta Developer account credentials for camazotz IdP integration
# Copy this file to compose/.env.okta and fill in your values.
# See docs/guides/okta-setup.md for step-by-step instructions.

OKTA_ISSUER_URL=https://dev-XXXXXX.okta.com/oauth2/default
OKTA_TOKEN_ENDPOINT=https://dev-XXXXXX.okta.com/oauth2/default/v1/token
OKTA_INTROSPECTION_ENDPOINT=https://dev-XXXXXX.okta.com/oauth2/default/v1/introspect
OKTA_REVOCATION_ENDPOINT=https://dev-XXXXXX.okta.com/oauth2/default/v1/revoke
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret
