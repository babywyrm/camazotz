BRAIN_PROVIDER=cloud
ANTHROPIC_API_KEY=
CAMAZOTZ_MODEL=claude-sonnet-4-20250514

# Optional: Amazon Bedrock — set BRAIN_PROVIDER=bedrock and configure:
# AWS_REGION=
# AWS_PROFILE=
# For Docker, you often need explicit keys (containers do not read ~/.aws):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# CAMAZOTZ_MODEL=  # inference profile or model id for Bedrock
# CAMAZOTZ_BEDROCK_STUB=1  # offline stub, no AWS calls

CAMAZOTZ_DIFFICULTY=medium
CAMAZOTZ_SHOW_TOKENS=false

# Identity provider (deployment default: zitadel). Runtime falls back to mock when config is incomplete.
CAMAZOTZ_IDP_PROVIDER=zitadel
CAMAZOTZ_IDP_ISSUER_URL=http://zitadel:8080
CAMAZOTZ_IDP_TOKEN_ENDPOINT=http://zitadel:8080/oauth/v2/token
CAMAZOTZ_IDP_INTROSPECTION_ENDPOINT=http://zitadel:8080/oauth/v2/introspect
CAMAZOTZ_IDP_REVOCATION_ENDPOINT=http://zitadel:8080/oauth/v2/revoke
CAMAZOTZ_IDP_CLIENT_ID=camazotz-gateway
CAMAZOTZ_IDP_CLIENT_SECRET=
ZITADEL_MASTERKEY=CamazotzZitadelMasterKeyValue123
ZITADEL_DB_PASSWORD=camazotz-zitadel-postgres
OLLAMA_HOST=http://ollama:11434
CAMAZOTZ_OLLAMA_MODEL=llama3.2:3b
FLASK_SECRET=cztz-dev-key
OBSERVER_POLL_INTERVAL=2
OBSERVER_BUFFER_SIZE=50
LOG_LEVEL=info

# Lab secrets (seeded into the container for secrets_lab realism)
CZTZ_SECRET_DATABASE_URL=postgresql://admin:s3cretPassw0rd!@10.0.3.12:5432/prod_db
CZTZ_SECRET_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
CZTZ_SECRET_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
CZTZ_SECRET_REDIS_PASSWORD=r3dis-hunter2-prod
CZTZ_SECRET_KEYCLOAK_CLIENT_SECRET=cztz-kc-9f8a7b6c5d4e3f2a1b0c
